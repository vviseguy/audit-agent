{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Finding",
  "description": "Detailed Delver output. Citation is mandatory and checked at ingest.",
  "type": "object",
  "required": [
    "vulnerability_id",
    "cwe_id",
    "path",
    "line_start",
    "line_end",
    "title",
    "severity",
    "exploit_scenario",
    "remediation",
    "confidence"
  ],
  "properties": {
    "vulnerability_id": { "type": "integer" },
    "cwe_id": { "type": "string", "pattern": "^CWE-[0-9]+$" },
    "path": { "type": "string", "description": "Repo-relative, must exist in the clone." },
    "line_start": { "type": "integer", "minimum": 1 },
    "line_end": { "type": "integer", "minimum": 1 },
    "title": { "type": "string" },
    "severity": {
      "type": "string",
      "enum": ["info", "low", "medium", "high", "critical"]
    },
    "exploit_scenario": { "type": "string" },
    "remediation": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "references": {
      "type": "array",
      "items": { "type": "string" }
    },
    "related_draft_issue_ids": {
      "type": "array",
      "items": { "type": "integer" },
      "description": "If the Delver updated existing drafts instead of creating new ones."
    }
  },
  "additionalProperties": false
}
